# Copy to .env.local and fill only what you need.
# Do not commit .env.local.
# Public beta / marketing-only deploy on Vercel Hobby:
# - only NEXT_PUBLIC_APP_URL is recommended
# - set NEXT_PUBLIC_DISABLE_SUPABASE=true to keep the public beta independent from Supabase
NEXT_PUBLIC_APP_URL=https://yourdomain.vercel.app
NEXT_PUBLIC_DISABLE_SUPABASE=true

# Optional for backoffice / advanced modules only:
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
EMAIL_INBOUND_TOKEN=replace-with-random-inbound-token
INBOUND_DEFAULT_TENANT_ID=optional-tenant-uuid-for-inbound-mvp
RESEND_API_KEY=your-resend-api-key
AGENCY_BOOKING_FROM_EMAIL=booking@yourdomain.com
AGENCY_BOOKING_BETA_RECIPIENT_EMAIL=
NEXT_PUBLIC_AGENCY_DEFAULT_CONFIRMATION_EMAIL=
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=rennasday@gmail.com
IMAP_PASS=your-gmail-app-password
IMAP_TLS=true
IMAP_MAILBOX=INBOX
WHATSAPP_TOKEN=your-whatsapp-cloud-api-access-token
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_VERIFY_TOKEN=replace-with-random-verify-token
WHATSAPP_TEMPLATE_NAME=transfer_reminder
WHATSAPP_TEMPLATE_LANGUAGE=it
WHATSAPP_ALLOW_TEXT_FALLBACK=false
CRON_SECRET=replace-with-random-cron-secret
WHATSAPP_CRON_SECRET=replace-with-random-cron-secret
WHATSAPP_REMINDER_WINDOW_MINUTES=15
WHATSAPP_REMINDER_2H_ENABLED=false
NEXT_PUBLIC_REMINDER_ALERT_MINUTES=30
