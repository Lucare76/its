# Copy to .env.local and fill real values.
# Do not commit .env.local.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_APP_URL=https://yourdomain.vercel.app
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
EMAIL_INBOUND_TOKEN=replace-with-random-inbound-token
INBOUND_DEFAULT_TENANT_ID=optional-tenant-uuid-for-inbound-mvp
WHATSAPP_TOKEN=your-whatsapp-cloud-api-access-token
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_VERIFY_TOKEN=replace-with-random-verify-token
WHATSAPP_TEMPLATE_NAME=transfer_reminder
WHATSAPP_TEMPLATE_LANGUAGE=it
WHATSAPP_ALLOW_TEXT_FALLBACK=false
CRON_SECRET=replace-with-random-cron-secret
WHATSAPP_CRON_SECRET=replace-with-random-cron-secret
WHATSAPP_REMINDER_WINDOW_MINUTES=15
WHATSAPP_REMINDER_2H_ENABLED=false
NEXT_PUBLIC_REMINDER_ALERT_MINUTES=30
