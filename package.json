{
  "name": "ischia-transfer-beta",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "dev": "next dev --port 3010",
    "dev:3010": "next dev --port 3010",
    "dev:safe": "scripts\\start-safe-dev.cmd",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "e2e": "pnpm exec playwright test",
    "e2e:ops": "pnpm exec playwright test tests/e2e/pdf-ops.spec.ts --workers=1 --reporter=line",
    "e2e:ui": "pnpm exec playwright test --ui",
    "e2e:headed": "pnpm exec playwright test --headed",
    "seed:demo": "node scripts/seed-demo.mjs",
    "seed:sample-pdf": "node scripts/process-sample-pdf.mjs",
    "inbound:test": "node scripts/test-inbound.mjs",
    "db:bootstrap": "node scripts/db-sql-editor.mjs bootstrap",
    "db:seed": "node scripts/db-sql-editor.mjs seed"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@supabase/supabase-js": "^2.57.2",
    "clsx": "^2.1.1",
    "imapflow": "^1.2.12",
    "leaflet": "^1.9.4",
    "mailparser": "^3.9.3",
    "next": "^16.0.0",
    "pdf-parse": "^1.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.53.2",
    "react-leaflet": "^4.2.1",
    "react-leaflet-cluster": "^2.1.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/leaflet": "^1.9.17",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.10.2",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  }
}
